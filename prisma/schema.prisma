// Dispatch — client portal schema
// See docs/plans/2026-05-04-dispatch-client-portal-design.md (Data model section)
// Auth identities live in Supabase's auth.users table; ClientAccount.authUserId
// holds that uuid as a string (Prisma does not model the cross-schema FK).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ClientAccount {
  id         String   @id @default(cuid())
  authUserId String   @unique @map("auth_user_id")
  email      String   @unique
  name       String
  avatarPath String?  @map("avatar_path")
  createdAt  DateTime @default(now()) @map("created_at")

  sites   Site[]
  tickets Ticket[]
  emailChangeRequests EmailChangeRequest[]
  addOnPrices  AddOnClientPrice[]
  clientAddOns ClientAddOn[]

  @@map("client_accounts")
}

model Site {
  id                  String    @id @default(cuid())
  clientAccountId     String    @map("client_account_id")
  url                 String
  displayName         String    @map("display_name")
  addedAt             DateTime  @default(now()) @map("added_at")
  productionStartedAt DateTime? @map("production_started_at")

  clientAccount ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)
  tickets       Ticket[]
  clientAddOns  ClientAddOn[]

  @@unique([clientAccountId, url])
  @@map("sites")
}

model Invite {
  id                  String    @id @default(cuid())
  token               String    @unique
  email               String
  recipientName       String?   @map("recipient_name")
  siteUrl             String    @map("site_url")
  siteDisplayName     String    @map("site_display_name")
  note                String?
  expiresAt           DateTime  @map("expires_at")
  redeemedAt          DateTime? @map("redeemed_at")
  redeemedByAccountId String?   @map("redeemed_by_account_id")
  revokedAt           DateTime? @map("revoked_at")
  reminderSentAt      DateTime? @map("reminder_sent_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([token])
  @@map("invites")
}

model Ticket {
  id              String         @id @default(cuid())
  clientAccountId String         @map("client_account_id")
  siteId          String         @map("site_id")
  title           String
  description     String         @db.Text
  category        TicketCategory
  status          TicketStatus   @default(NEW)
  attachments     Json?
  addOnId         String?        @map("add_on_id")
  isInquiry      Boolean   @default(false) @map("is_inquiry")
  inquiryEndedAt DateTime? @map("inquiry_ended_at")
  lastMessageAt  DateTime? @map("last_message_at")
  adminNudgedAt  DateTime? @map("admin_nudged_at")
  isEmergency             Boolean @default(false) @map("is_emergency")
  emergencyFeeAmountCents Int?    @map("emergency_fee_amount_cents")

  // 6-stage progress timestamps
  createdAt          DateTime  @default(now()) @map("created_at")
  receivedAt         DateTime? @map("received_at")
  firstViewedAt      DateTime? @map("first_viewed_at")
  reviewingStartedAt DateTime? @map("reviewing_started_at")
  fixingStartedAt    DateTime? @map("fixing_started_at")
  fixedAt            DateTime? @map("fixed_at")
  confirmedAt        DateTime? @map("confirmed_at")
  reopenedAt         DateTime? @map("reopened_at")

  clientAccount ClientAccount @relation(fields: [clientAccountId], references: [id])
  site          Site          @relation(fields: [siteId], references: [id])
  messages      Message[]
  addOn         AddOn?        @relation(fields: [addOnId], references: [id])
  activatedAddOns ClientAddOn[] @relation("AddOnRequestTicket")

  @@index([clientAccountId])
  @@index([siteId])
  @@index([status])
  @@index([isInquiry, inquiryEndedAt])
  @@index([clientAccountId, isInquiry, inquiryEndedAt])
  @@index([addOnId])
  @@map("tickets")
}

model Message {
  id          String     @id @default(cuid())
  ticketId    String     @map("ticket_id")
  senderType  SenderType @map("sender_type")
  senderId    String     @map("sender_id")
  body        String     @db.Text
  attachments Json?
  readAt      DateTime?  @map("read_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@map("messages")
}

model AddOn {
  id          String         @id @default(cuid())
  name        String
  description String         @db.Text
  kind        AddOnKind
  scope       AddOnScope
  priceType      AddOnPriceType @default(FIXED) @map("price_type")
  priceCents     Int            @map("price_cents")
  priceMaxCents  Int?           @map("price_max_cents")
  pricePercentBp Int?           @map("price_percent_bp")
  priceUnit      AddOnPriceUnit @map("price_unit")
  priceUnitLabel String?        @map("price_unit_label")
  isActive       Boolean        @default(true) @map("is_active")
  sortOrder   Int            @default(0) @map("sort_order")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  clientPrices AddOnClientPrice[]
  clientAddOns ClientAddOn[]
  tickets      Ticket[]

  @@index([isActive, sortOrder])
  @@map("add_ons")
}

model AddOnClientPrice {
  id              String         @id @default(cuid())
  addOnId         String         @map("add_on_id")
  clientAccountId String         @map("client_account_id")
  priceType       AddOnPriceType @default(FIXED) @map("price_type")
  priceCents      Int            @map("price_cents")
  priceMaxCents   Int?           @map("price_max_cents")
  pricePercentBp  Int?           @map("price_percent_bp")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  addOn         AddOn         @relation(fields: [addOnId], references: [id], onDelete: Cascade)
  clientAccount ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)

  @@unique([addOnId, clientAccountId])
  @@index([clientAccountId])
  @@map("add_on_client_prices")
}

model ClientAddOn {
  id               String            @id @default(cuid())
  clientAccountId  String            @map("client_account_id")
  addOnId          String            @map("add_on_id")
  siteId           String?           @map("site_id")
  status           ClientAddOnStatus @default(ACTIVE)
  priceCents       Int               @map("price_cents")
  startedAt        DateTime          @default(now()) @map("started_at")
  endedAt          DateTime?         @map("ended_at")
  requestTicketId  String?           @map("request_ticket_id")
  note             String?           @db.Text
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  clientAccount ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)
  addOn         AddOn         @relation(fields: [addOnId], references: [id])
  site          Site?         @relation(fields: [siteId], references: [id], onDelete: SetNull)
  requestTicket Ticket?       @relation("AddOnRequestTicket", fields: [requestTicketId], references: [id], onDelete: SetNull)

  @@index([clientAccountId, status])
  @@index([addOnId])
  @@index([siteId])
  @@map("client_add_ons")
}

enum AddOnKind {
  RECURRING
  ONE_TIME
}

enum AddOnScope {
  PER_SITE
  PER_CLIENT
}

enum AddOnPriceUnit {
  ONE_TIME
  PER_MONTH
  PER_YEAR
  ON_TOTAL_BUILD
}

enum AddOnPriceType {
  FIXED
  RANGE
  PERCENTAGE
}

enum ClientAddOnStatus {
  ACTIVE
  PAUSED
  ENDED
}

enum SenderType {
  CLIENT
  ADMIN
}

enum TicketStatus {
  NEW
  REVIEWING
  FIXING
  AWAITING_CONFIRMATION
  CLOSED
  REOPENED
}

enum TicketCategory {
  BUG
  CONTENT
  FEATURE
  QUESTION
  URGENT
  UPDATE
}

/// Singleton row keyed by id="global". Stores admin-controlled availability
/// settings: weekly business hours, IANA timezone, and out-of-office state.
model AdminSettings {
  id          String    @id                    // always "global"
  timezone    String    @default("America/New_York")
  hours       Json      // { "0": { enabled:false }, "1": { enabled:true, open:"09:00", close:"17:00" }, ... }
  oooEnabled  Boolean   @default(false)        @map("ooo_enabled")
  oooFrom     DateTime?                         @map("ooo_from")
  oooUntil    DateTime?                         @map("ooo_until")
  oooMessage  String?                           @map("ooo_message")
  holidays           String[] @default([])
  emergencyFeeCents  Int      @default(5000) @map("emergency_fee_cents")
  outOfTown          Boolean  @default(false) @map("out_of_town")
  updatedAt   DateTime  @updatedAt              @map("updated_at")

  @@map("admin_settings")
}

/// One scheduled vacation. start_date and end_date are calendar dates in the
/// admin's timezone (no time-of-day, no UTC math). end_date is INCLUSIVE —
/// the day after end_date is when outOfTown flips back off.
model Vacation {
  id        String   @id @default(cuid())
  label     String?
  startDate DateTime @db.Date  @map("start_date")
  endDate   DateTime @db.Date  @map("end_date")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([startDate, endDate])
  @@map("vacations")
}

model EmailChangeRequest {
  id              String    @id @default(cuid())
  clientAccountId String    @map("client_account_id")
  newEmail        String    @map("new_email")
  tokenHash       String    @unique @map("token_hash")
  expiresAt       DateTime  @map("expires_at")
  consumedAt      DateTime? @map("consumed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  clientAccount ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)

  @@index([clientAccountId])
  @@index([newEmail])
  @@map("email_change_requests")
}
