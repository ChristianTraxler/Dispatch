# Dispatch — environment schema (committed; no secrets)
#
# Copy two files when bootstrapping a new clone:
#   cp .env.example .env        # Prisma CLI reads DATABASE_URL from .env
#   cp .env.example .env.local  # Next.js loads .env.local (overrides .env)
# Then fill in real values from Supabase + Resend dashboards.

# Database (read by Prisma CLI from .env; Next.js will also pick it up)
DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=ticket-attachments

# Resend
RESEND_API_KEY=
RESEND_FROM="Dispatch <support@developerofcode.com>"

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAIL=hello@developerofcode.com
